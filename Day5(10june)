class Solution {
    public boolean isPerfectSquare(int num) {
        long left=1;
        long right = num;        while(left<=right){
            long mid = left +(right-left)/2;
            long sqr=mid*mid;
            if(sqr==num){
                return true;
            }else if(sqr<num){
                left =mid +1;
            }else{
                right=mid-1;
            }
        }
        return false;
        
    }
}
//PROGRAM 4//
class Solution {
    public void reverseString(char[] s) {
        int start=0;
        int end=s.length -1;

        while(start<=end){
            char temp= s[start];
            s[start] = s[end];
            s[end]=temp;
            start++;
            end--;
        }
    }
}
