class Solution {
    public boolean isAnagram(String s, String t) {
       char[] a =s.toCharArray();
       char[] b =t.toCharArray();

       Arrays.sort(a);
       Arrays.sort(b);
       return Arrays.equals(a,b); 
    }
}
//PROGRAM 6//
class Solution {
    public int lengthOfLastWord(String s) {
        s=s.trim();
        int count=0;

        for(int i=s.length()-1;i>=0;i--){
            if(s.charAt(i)!=' '){
                count++;
            }else{
                break;
            }
        }
        return count;
    }
}
