//Middle of the Linked List


class Solution {
    public ListNode middleNode(ListNode head) {
        ListNode a=head;
        ListNode b=head;
        while(a!=null && a.next !=null){
            a=a.next.next;
            b=b.next;
            

        }
    return b;    
    }

}

